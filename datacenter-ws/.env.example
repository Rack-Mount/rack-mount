# Copy this file to .env and fill in the values before running the server.
# .env is listed in .gitignore and must never be committed to version control.

SECRET_KEY=your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database
DB_NAME=rack_mount
DB_USER=rack
DB_PASSWORD=
DB_HOST=127.0.0.1
DB_PORT=3306
DB_CONN_MAX_AGE=60

# Signed URL secret (required in production, auto-derived from SECRET_KEY in DEBUG mode)
SIGNED_URL_SECRET=

# Redis cache (disabled by default in dev)
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_DB=1
REDIS_PASSWORD=
USE_REDIS_CACHE=False

# API/Swagger access whitelist (comma-separated IPs)
ACCESS_LIST=127.0.0.1

# CORS and CSRF allowed origins (comma-separated URLs, no trailing slashes)
CORS_ALLOWED_ORIGINS=http://localhost:4200,http://127.0.0.1:4200
CSRF_TRUSTED_ORIGINS=http://localhost:4200,http://127.0.0.1:4200

# Celery broker (Redis DB 2 by default, separate from cache on DB 1)
# Start worker: celery -A datacenter-app worker -l info
CELERY_BROKER_URL=redis://127.0.0.1:6379/2
